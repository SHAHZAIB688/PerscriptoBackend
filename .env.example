PORT=5000
NODE_ENV=development
# MongoDB Atlas (cloud) — replace USER, PASSWORD, CLUSTER with your Atlas values
# MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/doctorsonhand?retryWrites=true&w=majority
# Local Docker Mongo:
MONGO_URI=mongodb://admin:password@127.0.0.1:27017/doctorsonhand?authSource=admin
JWT_SECRET=super_secret_key
# Used for CORS and Socket.io; comma-separate multiple origins if needed
FRONTEND_URL=http://localhost:5173
STRIPE_SECRET_KEY=your_stripe_secret_key

# Twilio WhatsApp credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886

# Firebase Admin — paste full service account JSON as one line (Project settings → Service accounts → Generate new private key)
FIREBASE_PROJECT_ID=prescripto-e5247
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
